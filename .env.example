# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Terraform Backend
TF_STATE_BUCKET=cloud-platform-tf-state-123456789012
TF_STATE_KEY=staging/terraform.tfstate
TF_LOCK_TABLE=cloud-platform-tf-lock

# EKS
CLUSTER_NAME=cloud-platform-staging
K8S_VERSION=1.29
NODE_INSTANCE_TYPE=t3.medium
NODE_MIN=1
NODE_MAX=5
NODE_DESIRED=2

# Application
APP_NAME=cloud-platform-app
APP_IMAGE=cloud-platform-app
APP_PORT=80
HEALTH_CHECK_PATH=/health

# Project metadata
PROJECT=cloud-platform
ENVIRONMENT=staging
OWNER=platform-team
COST_CENTER=engineering
GITHUB_ORG=naman833

# GitHub Actions Secrets (set these in your repo settings)
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/cloud-platform-github-actions
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# ECR_REPOSITORY=cloud-platform-app
# TF_STATE_BUCKET=(same as above)
# TF_LOCK_TABLE=(same as above)
# AWS_ACCOUNT_ID=(same as above)
